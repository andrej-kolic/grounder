{
  "name": "grounder",
  "version": "0.0.1",
  "description": "Connect git projects to Obsidian dev vaults for AI agent memory",
  "type": "module",
  "bin": {
    "grounder": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "pnpm run build",
